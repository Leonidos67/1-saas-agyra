import React, { useState } from 'react';
import { HomeIcon, ChatBubbleLeftRightIcon, BellIcon, Cog6ToothIcon, FolderIcon, UserGroupIcon, ChartBarIcon, LifebuoyIcon, ArrowRightStartOnRectangleIcon } from '@heroicons/react/24/outline';
import { View } from '../../types';
import { mockViews } from '../../data/mockData';

interface SidebarProps {
  views?: View[];
}

const Sidebar: React.FC<SidebarProps> = ({ views = mockViews }) => {
  const [activeView, setActiveView] = useState('all');
  const [expandedSections, setExpandedSections] = useState<Record<string, boolean>>({
    tickets: true,
    views: true,
    categories: false,
    priorities: false
  });

  const toggleSection = (section: string) => {
    setExpandedSections((prev: Record<string, boolean>) => ({
      ...prev,
      [section]: !prev[section]
    }));
  };

  const navItems = [
    { name: 'Dashboard', icon: HomeIcon },
    { name: 'Tickets', icon: ChatBubbleLeftRightIcon },
    { name: 'Customers', icon: UserGroupIcon },
    { name: 'Reports', icon: ChartBarIcon },
    { name: 'Help Center', icon: LifebuoyIcon },
    { name: 'Settings', icon: Cog6ToothIcon },
  ];

  const categories = [
    { name: 'Technical Support', count: 8 },
    { name: 'Billing Inquiry', count: 5 },
    { name: 'Feature Request', count: 3 },
    { name: 'Bug Report', count: 12 },
    { name: 'Account Issue', count: 7 },
  ];

  const priorities = [
    { name: 'Critical', count: 2, color: 'text-red-600' },
    { name: 'High', count: 5, color: 'text-orange-600' },
    { name: 'Medium', count: 10, color: 'text-yellow-600' },
    { name: 'Low', count: 7, color: 'text-green-600' },
  ];

  return (
    <div className="w-64 bg-neutral-50 border-r border-neutral-200 flex flex-col h-full shadow-card">
      {/* Logo */}
      <div className="p-5 border-b border-neutral-200 bg-neutral-50">
        <h1 className="text-xl font-bold text-primary-700">Agyra<span className="font-light">SaaS</span></h1>
        <p className="text-xs text-neutral-500 mt-1">AI-Powered Support</p>
      </div>

      {/* Navigation */}
      <nav className="flex-1 py-4 overflow-y-auto">
        <ul className="space-y-1 px-2">
          {navItems.map((item) => (
            <li key={item.name}>
              <a
                href="#"
                className={`flex items-center p-3 rounded-lg transition-colors ${
                  item.name === 'Tickets' 
                    ? 'bg-primary-50 text-primary-700' 
                    : 'text-neutral-700 hover:bg-neutral-100'
                }`}
              >
                <item.icon className="h-5 w-5 mr-3" />
                <span>{item.name}</span>
              </a>
            </li>
          ))}
        </ul>

        {/* Views Section */}
        <div className="mt-6 px-2">
          <button
            onClick={() => toggleSection('views')}
            className="flex items-center justify-between w-full p-2 text-left text-neutral-700 font-medium rounded-lg hover:bg-neutral-100"
          >
            <span>Views</span>
            <svg 
              className={`h-4 w-4 transform transition-transform ${expandedSections.views ? 'rotate-180' : ''}`} 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor"
            >
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          {expandedSections.views && (
            <ul className="mt-2 space-y-1 ml-2">
              {views.map((view) => (
                <li key={view.id}>
                  <a
                    href="#"
                    onClick={(e) => {
                      e.preventDefault();
                      setActiveView(view.id);
                    }}
                    className={`flex items-center justify-between p-2 rounded-lg transition-colors ${
                      activeView === view.id
                        ? 'bg-primary-50 text-primary-700'
                        : 'text-neutral-600 hover:bg-neutral-100'
                    }`}
                  >
                    <span>{view.name}</span>
                    <span className="bg-neutral-200 text-neutral-700 text-xs font-medium px-2 py-0.5 rounded-full">
                      {view.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>

        {/* Categories Section */}
        <div className="mt-4 px-2">
          <button
            onClick={() => toggleSection('categories')}
            className="flex items-center justify-between w-full p-2 text-left text-neutral-700 font-medium rounded-lg hover:bg-neutral-100"
          >
            <span>Categories</span>
            <svg 
              className={`h-4 w-4 transform transition-transform ${expandedSections.categories ? 'rotate-180' : ''}`} 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor"
            >
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          {expandedSections.categories && (
            <ul className="mt-2 space-y-1 ml-2">
              {categories.map((category, index) => (
                <li key={index}>
                  <a
                    href="#"
                    className="flex items-center justify-between p-2 rounded-lg text-neutral-600 hover:bg-neutral-100"
                  >
                    <span>{category.name}</span>
                    <span className="bg-neutral-200 text-neutral-700 text-xs font-medium px-2 py-0.5 rounded-full">
                      {category.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>

        {/* Priorities Section */}
        <div className="mt-4 px-2">
          <button
            onClick={() => toggleSection('priorities')}
            className="flex items-center justify-between w-full p-2 text-left text-neutral-700 font-medium rounded-lg hover:bg-neutral-100"
          >
            <span>Priorities</span>
            <svg 
              className={`h-4 w-4 transform transition-transform ${expandedSections.priorities ? 'rotate-180' : ''}`} 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor"
            >
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
            </svg>
          </button>

          {expandedSections.priorities && (
            <ul className="mt-2 space-y-1 ml-2">
              {priorities.map((priority, index) => (
                <li key={index}>
                  <a
                    href="#"
                    className={`flex items-center justify-between p-2 rounded-lg hover:bg-neutral-100 ${priority.color}`}
                  >
                    <span>{priority.name}</span>
                    <span className="bg-neutral-200 text-neutral-700 text-xs font-medium px-2 py-0.5 rounded-full">
                      {priority.count}
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          )}
        </div>
      </nav>

      {/* User Profile */}
      <div className="p-4 border-t border-neutral-200">
        <div className="flex items-center">
          <div className="bg-primary-100 text-primary-800 w-10 h-10 rounded-full flex items-center justify-center font-semibold">
            AJ
          </div>
          <div className="ml-3">
            <p className="text-sm font-medium text-neutral-900">Алекс Джонсон</p>
            <p className="text-xs text-neutral-500">admin@example.com</p>
          </div>
          <button className="ml-auto text-neutral-400 hover:text-neutral-600">
            <ArrowRightStartOnRectangleIcon className="h-5 w-5" />
          </button>
        </div>
      </div>
    </div>
  );
};

export default Sidebar;
    </div>
  );
};

export default Sidebar;